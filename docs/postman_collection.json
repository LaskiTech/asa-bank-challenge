  "info": {
    "_postman_id": "0f61b785-8cdc-4757-9454-e5da7cb171c4",
    "name": "ASA Bank - POS Transaction API",
    "description": "Postman collection for the POS Transaction API middleware. Handles authorize, confirm, and void operations with HMAC SHA-256 security.\n\n**HMAC Signature**: The `X-Signature` header must be `HMAC-SHA256(raw JSON body, SHARED_SECRET)` in hex. Use the pre-request scripts to auto-generate it via the CryptoJS library bundled in Postman.\n\n**Timestamp**: `X-Timestamp` must be an ISO-8601 UTC timestamp within ±5 minutes of server time.\n\n**Variables**: Set `baseUrl` (default: `http://localhost:3000`) and `sharedSecret` (default: `dev-secret-key-change-in-production`) in the collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "26305634"
  },
