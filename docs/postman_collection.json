    {
      "name": "Transactions",
      "item": [
        {
          "name": "POST /authorize",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pega o body cru da aba Body e resolve variáveis {{...}} dentro dele",
                  "const rawBody = pm.variables.replaceIn(pm.request.body.raw || '');",
                  "",
                  "const secret = pm.collectionVariables.get('sharedSecret');",
                  "const timestamp = new Date().toISOString();",
                  "",
                  "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.variables.set('_signature', signature);",
                  "pm.variables.set('_timestamp', timestamp);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.test('Response has transactionId', () => pm.expect(json).to.have.property('transactionId'));",
                  "    pm.test('Status is AUTHORIZED', () => pm.expect(json.status).to.eql('AUTHORIZED'));",
                  "    // Persist transactionId for use in confirm / void requests",
                  "    pm.collectionVariables.set('transactionId', json.transactionId);",
                  "    console.log('transactionId saved:', json.transactionId);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
