        {
          "name": "401 — Expired Timestamp",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Timestamp 10 minutes in the past",
                  "const tenMinutesAgo = new Date(Date.now() - 10 * 60 * 1000).toISOString();",
                  "pm.variables.set('_oldTimestamp', tenMinutesAgo);",
                  "",
                  "// Signature is still valid for the body (to isolate the timestamp failure)",
                  "const body = { nsu: '123456', amount: 199.90, terminalId: 'T-1000' };",
                  "const secret = pm.collectionVariables.get('sharedSecret');",
                  "const sig = CryptoJS.HmacSHA256(JSON.stringify(body), secret).toString(CryptoJS.enc.Hex);",
                  "pm.variables.set('_signature', sig);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error is timestamp_out_of_range', () => {",
                  "    pm.expect(pm.response.json().error).to.match(/timestamp/);",
                  "});"
                ]
              }
            }
